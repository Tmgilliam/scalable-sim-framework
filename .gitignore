# Project-local exclusions. The parent monorepo .gitignore also covers
# __pycache__/, .pytest_cache/, .venv/, .env, IDE files.
# This file is the union of the v1 standalone .gitignore and v2 additions.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Env / secrets
.env
*.pem

# OS
.DS_Store
Thumbs.db

# Sim run outputs (generated, not source).
# Historical run directories from v1 and v2 that were committed
# pre-convergence are still tracked. Newly generated run dirs
# (named with a 4-digit-year prefix) are treated as ephemeral.
runs/2*/

# Local Vertex AI component sandbox (transient artifacts from
# `python -m vertex.pipeline ...` runs; per-developer, not provenance).
runs/vertex_local/

# Executed notebook outputs (regenerated by reports/build_notebook.py).
reports/exec_summary_executed.ipynb

# Streamlit local config (per-developer)
.streamlit/secrets.toml
